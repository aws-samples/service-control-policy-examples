{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "DenyCreatingAnyServiceSpecificWithExceptionBasedOnTag",
      "Effect": "Deny",
      "Action": "iam:CreateServiceSpecificCredential",
      "Resource": "*",
      "Condition": {
        "StringEqualsIfExists": {
          "iam:ServiceSpecificCredentialServiceName": [
            "logs.amazonaws.com",
            "bedrock.amazonaws.com",
            "cassandra.amazonaws.com"
            //add or remove the list of service as you need. Please note that AWS IAM does not support comments, so please remove this line when using this policy
          ]
        }
      }
    }
  ]
}
