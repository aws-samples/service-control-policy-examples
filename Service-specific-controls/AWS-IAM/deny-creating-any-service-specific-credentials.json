{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "DenyCreatingAnyServiceSpecificCredential",
      "Effect": "Deny",
      "Action": "iam:CreateServiceSpecificCredential",
      "Resource": "*"
    },
    {
      "Sid": "DenyCreatingAnyServiceSpecificWithExceptionBasedOnTag",
      "Effect": "Deny",
      "Action": "iam:CreateServiceSpecificCredential",
      "Resource": "*",
      "Condition": {
        "StringNotEqualsIfExists": {
          "iam:ResourceTag/ServiceSpecificCredentialAllowed": "true"
        }
      }
    }
  ]
}
