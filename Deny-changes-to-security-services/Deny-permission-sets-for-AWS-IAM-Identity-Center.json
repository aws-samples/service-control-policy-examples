{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Effect": "Deny",
      "Action": "sso:*",
      "Resource": [
        "arn:aws:sso:::permissionSet/*/*"
      ]
    },
    {
      "Sid": "DenySAMLProviderChanges",
      "Effect": "Deny",
      "Action": [
        "iam:UpdateSAMLProvider",
        "iam:DeleteSAMLProvider"
      ],
      "Resource": [
        "arn:aws:iam::*:saml-provider/AWSSSO_*"
      ]
    }
  ]
}
